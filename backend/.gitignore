## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
*/bin
*/obj

# Visual Studio Code workspace settings
.vscode/

# Rider
.idea/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Publish outputs
/publish/
*.publishsettings

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
/packages/
# NuGet v3's project.json files
project.lock.json

# Visual Studio cache files
*.cache
*.ilk
*.meta
*.obj
*.pdb
*.log

# Others
.DS_Store
Thumbs.db

# IIS Express
/.vs/
/.vs/*
applicationhost.config
iisexpress/config

# User secrets
secrets.json

# EF Core / Migrations
*.db
*.sqlite

# Node/npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Front-end build output
wwwroot/lib/
wwwroot/dist/

# runtime files
*.pid

# Environment files
appsettings.*.json

# JetBrains Rider
/.idea/

# DotCover
*.dotCover

# End of file
